ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=PathFinder API

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pathfinder
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081
